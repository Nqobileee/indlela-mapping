# Application
APP_NAME=Mutsinga
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.mutsinga.com

# Backend Server
PORT=8000
API_VERSION=v1


# Database (PostgreSQL + PostGIS)
DATABASE_HOST=your-postgres-host
DATABASE_PORT=5432
DATABASE_NAME=mutsinga_gis
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password
DATABASE_URL=postgresql://postgres:password@host:5432/indlela_gis


# Cloud Storage (Images, PDFs, Survey Files)
STORAGE_PROVIDER=aws

AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=af-south-1
AWS_BUCKET_NAME=mutsinga-assets


# Map Services
MAP_PROVIDER=mapbox

MAPBOX_ACCESS_TOKEN=your_mapbox_token


# Authentication
JWT_SECRET=your_secret_key
JWT_EXPIRATION=7d

# User roles
ENABLE_COMPANY_ROLES=true


# Mobile App Sync
SYNC_INTERVAL=300
MAX_UPLOAD_SIZE_MB=50


# AI Services
AI_ENABLED=true
AI_MODEL_PATH=models/mutsinga_detector.pt

AI_SERVICE_URL=https://ai.indle


# Image Processing
IMAGE_MAX_SIZE=4096
IMAGE_COMPRESSION=true


# Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@indlela.co.zw
SMTP_PASSWORD=password


# Logging
LOG_LEVEL=INFO


# Security
CORS_ALLOWED_ORIGINS=https://dashboard.indlela.co.zw